{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/drawings/generate3d.js": {
      "maxDuration": 120
    },
    "api/drawings/generatevideo.js": {
      "maxDuration": 30
    },
    "api/drawings/videostatus.js": {
      "maxDuration": 30
    },
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
